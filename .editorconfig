# Файл .editorconfig для .NET 10 / C# 13+
# Рекомендуется использовать с командой: dotnet format

root = true

[*]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{cs,csx,vb,vbx}]

#### Правила форматирования (Formatting) ####

# Новые строки
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_between_query_expression_clauses = true

# Отступы
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left

# Пробелы
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true

#### Правила стиля кода (Code Style) ####

# Использование var (обязательно, когда это возможно)
csharp_style_var_for_built_in_types = true:error
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_elsewhere = true:error

# Настройки языка (Modern C#)
csharp_style_namespace_declarations = file_scoped:error
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:none
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# Использование using
csharp_using_directive_placement = outside_namespace:suggestion
dotnet_separate_import_directive_groups = true
dotnet_sort_system_directives_first = true

# Общая чистота форматирования
dotnet_diagnostic.IDE0055.severity = warning

# Модификаторы
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion
dotnet_style_readonly_field = true:error

#### Правила именования (Naming Conventions) ####

# Интерфейсы должны начинаться с I
dotnet_naming_rule.interfaces_should_be_begun_with_i.severity = suggestion
dotnet_naming_rule.interfaces_should_be_begun_with_i.symbols = interface_types
dotnet_naming_rule.interfaces_should_be_begun_with_i.style = prefix_i

dotnet_naming_symbols.interface_types.applicable_kinds = interface

dotnet_naming_style.prefix_i.required_prefix = I
dotnet_naming_style.prefix_i.capitalization = pascal_case

# Приватные поля начинаются с _
dotnet_naming_rule.private_fields_should_start_with_underscore.severity = suggestion
dotnet_naming_rule.private_fields_should_start_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_start_with_underscore.style = prefix_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.prefix_underscore.required_prefix = _
dotnet_naming_style.prefix_underscore.capitalization = camel_case

# Публичные элементы (PascalCase)
dotnet_naming_rule.members_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.members_should_be_pascal_case.symbols = public_members
dotnet_naming_rule.members_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.public_members.applicable_kinds = property, method, event
dotnet_naming_symbols.public_members.applicable_accessibilities = public, internal, protected

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

#### Анализаторы (Analyzers) ####

# Удалять неиспользуемые using
dotnet_diagnostic.IDE0005.severity = error

# Упрощать инициализацию объектов (new())
dotnet_diagnostic.IDE0090.severity = suggestion

# Использовать 'is null' вместо '== null'
dotnet_diagnostic.IDE0041.severity = suggestion

[*.cs]
csharp_style_namespace_declarations = file_scoped:suggestion